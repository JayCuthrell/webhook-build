[
  {
    "id": "redeploy-fudge",
    "execute-command": "/home/jay/github/webhook-build/deploy.sh",
    "command-working-directory": "/home/jay/github/webhook-build/",
    "trigger-rule": {
      "match": {
        "type": "payload-hash-sha1",
        "secret": "{{ getenv \"GITHUB_WEBHOOK_SECRET\" }}",
        "parameter": {
          "source": "header",
          "name": "X-Hub-Signature"
        }
      }
    }
  }
]
